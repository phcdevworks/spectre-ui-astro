{
  "name": "@phcdevworks/spectre-ui-astro",
  "version": "2.10.0",
  "description": "@phcdevworks/spectre-ui-astro is the Astro adapter package of the Spectre system for Astro applications that consume the core Spectre UI contract.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-ui",
    "spectre-design-system",
    "design-system",
    "ui-library",
    "ui-components",
    "component-library",
    "astro",
    "astro-integration",
    "astro-component",
    "astro-component-library",
    "typescript",
    "ssr",
    "tailwindcss",
    "design-tokens"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui-astro.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui-astro/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui-astro#readme",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/SpAlert.astro": "./dist/components/SpAlert.astro",
    "./components/SpAvatar.astro": "./dist/components/SpAvatar.astro",
    "./components/SpBadge.astro": "./dist/components/SpBadge.astro",
    "./components/SpButton.astro": "./dist/components/SpButton.astro",
    "./components/SpCard.astro": "./dist/components/SpCard.astro",
    "./components/SpContainer.astro": "./dist/components/SpContainer.astro",
    "./components/SpDropdown.astro": "./dist/components/SpDropdown.astro",
    "./components/SpGrid.astro": "./dist/components/SpGrid.astro",
    "./components/SpIconBox.astro": "./dist/components/SpIconBox.astro",
    "./components/SpInput.astro": "./dist/components/SpInput.astro",
    "./components/SpModal.astro": "./dist/components/SpModal.astro",
    "./components/SpNav.astro": "./dist/components/SpNav.astro",
    "./components/SpPricingCard.astro": "./dist/components/SpPricingCard.astro",
    "./components/SpRating.astro": "./dist/components/SpRating.astro",
    "./components/SpFooter.astro": "./dist/components/SpFooter.astro",
    "./components/SpSection.astro": "./dist/components/SpSection.astro",
    "./components/SpSidebar.astro": "./dist/components/SpSidebar.astro",
    "./components/SpSpinner.astro": "./dist/components/SpSpinner.astro",
    "./components/SpStack.astro": "./dist/components/SpStack.astro",
    "./components/SpTag.astro": "./dist/components/SpTag.astro",
    "./components/SpTestimonial.astro": "./dist/components/SpTestimonial.astro",
    "./components/SpToast.astro": "./dist/components/SpToast.astro",
    "./components/SpTooltip.astro": "./dist/components/SpTooltip.astro"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && npm run build:types && node --experimental-strip-types scripts/copy-components.ts && node --experimental-strip-types scripts/validate-package-contract.ts && node --experimental-strip-types scripts/validate-readme-contract.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "check": "npm run ci:verify && npm run check:ecosystem",
    "ci:verify": "npm run lint && npm run build && npm run typecheck && npm test",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "release:propose": "node --experimental-strip-types scripts/propose-version.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run build",
    "check:ecosystem": "spectre-manifest-validate spectre.manifest.json && spectre-manifest-check spectre.manifest.json ."
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "peerDependencies": {
    "@phcdevworks/spectre-tokens": "^3.1.0",
    "@phcdevworks/spectre-ui": "^2.3.0",
    "astro": "^6.1.3",
    "typescript": "^5.9 || ^6.0"
  },
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "dependencies": {},
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@phcdevworks/spectre-tokens": "^3.1.0",
    "@phcdevworks/spectre-ui": "^2.3.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "astro": "^6.4.8",
    "eslint": "^10.5.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "@phcdevworks/spectre-manifest": "^1.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true
  }
}

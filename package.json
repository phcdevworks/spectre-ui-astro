{
  "name": "@phcdevworks/spectre-ui-astro",
  "version": "2.0.0",
  "description": "Layer 3 of the Spectre suite: Astro components that wrap Spectre UI recipes and styles.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-ui",
    "spectre-design-system",
    "design-system",
    "ui-library",
    "ui-components",
    "component-library",
    "astro",
    "astro-integration",
    "astro-component",
    "astro-component-library",
    "typescript",
    "ssr",
    "tailwindcss",
    "design-tokens"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-ui-astro.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-ui-astro/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-ui-astro#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components/SpBadge.astro": "./dist/components/SpBadge.astro",
    "./components/SpButton.astro": "./dist/components/SpButton.astro",
    "./components/SpCard.astro": "./dist/components/SpCard.astro",
    "./components/SpIconBox.astro": "./dist/components/SpIconBox.astro",
    "./components/SpInput.astro": "./dist/components/SpInput.astro",
    "./components/SpPricingCard.astro": "./dist/components/SpPricingCard.astro",
    "./components/SpRating.astro": "./dist/components/SpRating.astro",
    "./components/SpTestimonial.astro": "./dist/components/SpTestimonial.astro"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && npm run build:types && node scripts/copy-components.mjs",
    "build:types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "peerDependencies": {
    "astro": "^6.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-ui": "^1.1.0"
  },
  "devDependencies": {
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "chroma-js": "^3.2.0",
    "colord": "^2.9.3",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}

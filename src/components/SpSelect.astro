---
import type { SelectRecipeOptions } from "@phcdevworks/spectre-ui";
import { getSelectClasses } from "@phcdevworks/spectre-ui";
import { omitUndefined } from "./sp-recipe-options.shared";

interface SpSelectProps extends SelectRecipeOptions {
  class?: string;
  id?: string;
  name?: string;
  value?: string;
  required?: boolean;
  multiple?: boolean;
  form?: string;
  "aria-label"?: string;
  "aria-describedby"?: string;
  "aria-invalid"?: boolean | "true" | "false" | "grammar" | "spelling";

  [key: string]: unknown;
}

const {
  size,
  state,
  fullWidth,
  pill,
  disabled,
  loading,
  focused,
  class: className,
  id,
  name,
  value,
  required,
  multiple,
  form,
  "aria-label": ariaLabel,
  "aria-describedby": ariaDescribedby,
  "aria-invalid": ariaInvalid,
  ...rest
} = Astro.props as SpSelectProps;

const classes = getSelectClasses(
  omitUndefined({ size, state, fullWidth, pill, disabled, loading, focused }),
);
const finalClass = [classes, className].filter(Boolean).join(" ");
---

<select
  class={finalClass}
  id={id}
  name={name}
  value={value}
  disabled={disabled}
  required={required}
  multiple={multiple}
  form={form}
  aria-label={ariaLabel}
  aria-invalid={ariaInvalid ?? (state === "invalid" ? "true" : undefined)}
  aria-describedby={ariaDescribedby}
  aria-disabled={disabled ? "true" : undefined}
  aria-busy={loading ? "true" : undefined}
  {...rest}
>
  <slot />
</select>

---
import { getInputClasses } from "@phcdevworks/spectre-ui";
import {
  resolveSpInputAccessibility,
  type SpInputProps,
} from "./sp-input.shared";

const {
  state,
  size,
  fullWidth,
  pill,
  as: Tag = "div",
  label,
  helperText,
  errorMessage,
  id,
  class: className,
  disabled,
  loading,
  focused,
  hovered,
  active,
  "aria-describedby": userDescribedBy,
  "aria-invalid": userAriaInvalid,
  ...rest
} = Astro.props as SpInputProps;

const isInputDisabled = disabled || state === "disabled" || loading;

const { inputId, helperId, errorId, describedBy } =
  resolveSpInputAccessibility({
    id,
    label,
    helperText,
    errorMessage,
    userDescribedBy,
  });

const finalState =
  loading
    ? "loading"
    : isInputDisabled
      ? "disabled"
      : errorMessage || state === "error"
        ? "error"
        : state;

const classes = getInputClasses({
  state: finalState,
  size,
  fullWidth,
  pill,
  focused,
  hovered,
  active,
});
const finalClass = [classes, className].filter(Boolean).join(" ");

const finalAriaInvalid =
  userAriaInvalid !== undefined
    ? String(userAriaInvalid)
    : finalState === "error"
      ? "true"
      : undefined;
---

<Tag class="sp-input-wrapper">
  {
    label && (
      <label class="sp-label" for={inputId}>
        {label}
      </label>
    )
  }

  <input
    id={inputId}
    class={finalClass}
    aria-invalid={finalAriaInvalid}
    aria-describedby={describedBy}
    disabled={isInputDisabled}
    aria-disabled={isInputDisabled ? "true" : undefined}
    aria-busy={loading ? "true" : undefined}
    {...rest}
  />

  {
    helperText && !errorMessage && (
      <p class="sp-helper-text" id={helperId}>
        {helperText}
      </p>
    )
  }

  {
    errorMessage && (
      <p class="sp-error-message" id={errorId}>
        {errorMessage}
      </p>
    )
  }
</Tag>

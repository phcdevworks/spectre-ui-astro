---
import type { TextareaRecipeOptions } from "@phcdevworks/spectre-ui";
import { getTextareaClasses } from "@phcdevworks/spectre-ui";
import { omitUndefined } from "./sp-recipe-options.shared";

interface SpTextareaProps extends TextareaRecipeOptions {
  class?: string;
  id?: string;
  name?: string;
  value?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  readonly?: boolean;
  form?: string;
  "aria-label"?: string;
  "aria-describedby"?: string;
  "aria-invalid"?: boolean | "true" | "false" | "grammar" | "spelling";

  [key: string]: unknown;
}

const {
  size,
  state,
  fullWidth,
  pill,
  disabled,
  loading,
  focused,
  class: className,
  id,
  name,
  value,
  placeholder,
  rows,
  required,
  readonly,
  form,
  "aria-label": ariaLabel,
  "aria-describedby": ariaDescribedby,
  "aria-invalid": ariaInvalid,
  ...rest
} = Astro.props as SpTextareaProps;

const classes = getTextareaClasses(
  omitUndefined({ size, state, fullWidth, pill, disabled, loading, focused }),
);
const finalClass = [classes, className].filter(Boolean).join(" ");
---

<textarea
  class={finalClass}
  id={id}
  name={name}
  placeholder={placeholder}
  rows={rows}
  disabled={disabled}
  required={required}
  readonly={readonly}
  form={form}
  aria-label={ariaLabel}
  aria-invalid={ariaInvalid ?? (state === "invalid" ? "true" : undefined)}
  aria-describedby={ariaDescribedby}
  aria-disabled={disabled ? "true" : undefined}
  aria-busy={loading ? "true" : undefined}
  {...rest}
>{value}</textarea>

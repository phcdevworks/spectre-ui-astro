---
import type { ModalRecipeOptions } from "@phcdevworks/spectre-ui";
import { getModalClasses, getModalOverlayClasses } from "@phcdevworks/spectre-ui";

type SpModalElement = "div" | "section";

interface SpModalProps extends ModalRecipeOptions {
  as?: SpModalElement;
  class?: string;
  id?: string;
  "aria-label"?: string;
  "aria-labelledby"?: string;
  "aria-describedby"?: string;

  [key: string]: unknown;
}

const {
  open,
  fullWidth,
  as: Tag = "div",
  class: className,
  id,
  "aria-label": ariaLabel,
  "aria-labelledby": ariaLabelledby,
  "aria-describedby": ariaDescribedby,
  ...rest
} = Astro.props as SpModalProps;

const overlayClasses = getModalOverlayClasses({ open });
const modalClasses = getModalClasses({ open, fullWidth });
const finalClass = [modalClasses, className].filter(Boolean).join(" ");
const isHidden = !open;
---

<div class={overlayClasses} aria-hidden={isHidden ? "true" : undefined}>
  <Tag
    class={finalClass}
    id={id}
    role="dialog"
    aria-modal="true"
    aria-hidden={isHidden ? "true" : undefined}
    aria-label={ariaLabel}
    aria-labelledby={ariaLabelledby}
    aria-describedby={ariaDescribedby}
    {...rest}
  >
    <slot />
  </Tag>
</div>

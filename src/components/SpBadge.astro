---
import type { BadgeRecipeOptions } from "@phcdevworks/spectre-ui";
import { getBadgeClasses } from "@phcdevworks/spectre-ui";

type SpBadgeElement = "span" | "div" | "a" | "button" | "li";

interface SpBadgeProps extends BadgeRecipeOptions {
  as?: SpBadgeElement;
  class?: string;

  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;

  type?: "button" | "submit" | "reset";

  [key: string]: any;
}

const {
  variant,
  size,
  interactive,
  as: Tag = "span",
  class: className,
  href,
  target,
  rel,
  type,
  ...rest
} = Astro.props as SpBadgeProps;

const classes = getBadgeClasses({
  variant,
  size,
  interactive,
});
const finalClass = [classes, className].filter(Boolean).join(" ");

const type = Tag === "button" ? (rest.type ?? "button") : undefined;
---

<Tag class={finalClass} type={type} {...rest}>
  <slot />
</Tag>

---
import type { BadgeRecipeOptions } from "@phcdevworks/spectre-ui";
import { getBadgeClasses } from "@phcdevworks/spectre-ui";
import { resolveInteractiveAttrs } from "./sp-interactive.shared";

type SpBadgeElement = "span" | "div" | "a" | "button" | "li" | "time" | "mark";

interface SpBadgeProps extends BadgeRecipeOptions {
  as?: SpBadgeElement;
  class?: string;

  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;

  type?: "button" | "submit" | "reset";
  datetime?: string;
  tabindex?: number;
  "aria-label"?: string;

  loading?: boolean;

  [key: string]: any;
}

const {
  variant,
  size,
  interactive,
  disabled,
  loading,
  hovered,
  focused,
  active,
  as: Tag = "span",
  class: className,
  href,
  target,
  rel,
  type,
  datetime,
  tabindex,
  "aria-label": ariaLabel,
  ...rest
} = Astro.props as SpBadgeProps;

const isBadgeDisabled = disabled || loading;

const classes = getBadgeClasses({
  variant,
  size,
  interactive,
  disabled: isBadgeDisabled,
  loading,
  hovered,
  focused,
  active,
});
const finalClass = [classes, className].filter(Boolean).join(" ");

const { finalType, finalHref, finalTabIndex } = resolveInteractiveAttrs({
  Tag,
  isDisabled: isBadgeDisabled,
  href,
  type,
  tabindex,
  interactive,
});
---

<Tag
  class={finalClass}
  href={finalHref}
  target={Tag === "a" ? target : undefined}
  rel={Tag === "a" ? rel : undefined}
  type={finalType}
  disabled={Tag === "button" && isBadgeDisabled ? true : undefined}
  role={interactive && Tag !== "button" && Tag !== "a" ? "button" : undefined}
  aria-disabled={isBadgeDisabled ? "true" : undefined}
  aria-busy={loading ? "true" : undefined}
  aria-label={ariaLabel}
  datetime={Tag === "time" ? datetime : undefined}
  tabindex={finalTabIndex}
  {...rest}
>
  <slot />
</Tag>

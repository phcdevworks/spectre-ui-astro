---
import type { BadgeRecipeOptions } from "@phcdevworks/spectre-ui";
import { getBadgeClasses } from "@phcdevworks/spectre-ui";

type SpBadgeElement = "span" | "div" | "a" | "button";

interface SpBadgeProps extends BadgeRecipeOptions {
  as?: SpBadgeElement;
  class?: string;

  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;

  type?: "button" | "submit" | "reset";

  [key: string]: any;
}

const {
  variant,
  size,
  interactive,
  as: Tag = "span",
  class: className,
  ...rest
} = Astro.props as SpBadgeProps;

const classes = getBadgeClasses({
  variant,
  size,
  interactive,
});
const finalClass = [classes, className].filter(Boolean).join(" ");
---

{
  Tag === "a" ? (
    <a class={finalClass} {...rest}>
      <slot />
    </a>
  ) : Tag === "button" ? (
    <button class={finalClass} type={rest.type ?? "button"} {...rest}>
      <slot />
    </button>
  ) : Tag === "div" ? (
    <div class={finalClass} {...rest}>
      <slot />
    </div>
  ) : (
    <span class={finalClass} {...rest}>
      <slot />
    </span>
  )
}

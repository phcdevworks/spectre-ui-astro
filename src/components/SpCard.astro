---
import { getCardClasses, type CardRecipeOptions } from "@phcdevworks/spectre-ui";

type SpCardElement =
  | "div"
  | "section"
  | "article"
  | "aside"
  | "header"
  | "footer"
  | "main"
  | "nav"
  | "a"
  | "button"
  | "li";

interface SpCardProps extends CardRecipeOptions {
  as?: SpCardElement;
  class?: string;

  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;

  type?: "button" | "submit" | "reset";

  [key: string]: any;
}

const {
  variant,
  interactive,
  padded,
  fullHeight,
  as: Tag = "div",
  class: className,
  ...rest
} = Astro.props as SpCardProps;

const classes = getCardClasses({ variant, interactive, padded, fullHeight });
const finalClass = [classes, className].filter(Boolean).join(" ");

const type = Tag === "button" ? (rest.type ?? "button") : undefined;
---

<Tag class={finalClass} type={type} {...rest}>
  <slot />
</Tag>

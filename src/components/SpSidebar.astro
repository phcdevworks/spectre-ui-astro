---
import type { SidebarRecipeOptions } from "@phcdevworks/spectre-ui";
import {
  getSidebarClasses,
  getSidebarBackdropClasses,
  getSidebarToggleClasses,
} from "@phcdevworks/spectre-ui";

type SpSidebarElement = "aside" | "div" | "nav";

interface SpSidebarProps extends SidebarRecipeOptions {
  as?: SpSidebarElement;
  class?: string;
  id?: string;
  "aria-label"?: string;
  toggleLabel?: string;
  /** Suppress the built-in toggle button, e.g. when rendering SpSidebarToggle in SpNav instead. */
  hideToggle?: boolean;

  [key: string]: unknown;
}

const {
  bordered,
  as: Tag = "aside",
  class: className,
  id,
  "aria-label": ariaLabel,
  toggleLabel = "Toggle sidebar",
  hideToggle = false,
  ...rest
} = Astro.props as SpSidebarProps;

const classes = getSidebarClasses({ bordered });
const finalClass = [classes, className].filter(Boolean).join(" ");
const backdropClass = getSidebarBackdropClasses();
const toggleClass = getSidebarToggleClasses();
const wrapperId = id ? `${id}-shell` : undefined;
---

<div class="sp-sidebar-shell" id={wrapperId} data-sidebar-open="false">
  {
    !hideToggle && (
      <button
        type="button"
        class={toggleClass}
        aria-label={toggleLabel}
        aria-controls={wrapperId}
        aria-expanded="false"
        data-sidebar-toggle
        data-sidebar-shell-target={wrapperId}
      >
        <slot name="toggle-icon">&#9776;</slot>
      </button>
    )
  }
  <div class={backdropClass} data-sidebar-backdrop></div>
  <Tag class={finalClass} id={id} aria-label={ariaLabel} {...rest}>
    <slot />
  </Tag>
</div>

<script>
  function getSidebarToggles(shell: HTMLElement) {
    const toggles = new Set(
      shell.querySelectorAll<HTMLElement>("[data-sidebar-toggle]"),
    );

    if (shell.id) {
      document
        .querySelectorAll<HTMLElement>("[data-sidebar-toggle][data-sidebar-shell-target]")
        .forEach((toggle) => {
          if (toggle.dataset.sidebarShellTarget === shell.id) toggles.add(toggle);
        });
    }

    return toggles;
  }

  function setSidebarOpen(shell: HTMLElement, isOpen: boolean) {
    shell.setAttribute("data-sidebar-open", String(isOpen));
    getSidebarToggles(shell).forEach((toggle) => {
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }

  function bindSidebarToggle(toggle: HTMLElement) {
    if (toggle.dataset.sidebarToggleBound === "true") return;
    toggle.dataset.sidebarToggleBound = "true";

    toggle.addEventListener("click", () => {
      const target = toggle.dataset.sidebarShellTarget;
      const shell = target
        ? document.getElementById(target)
        : toggle.closest<HTMLElement>(".sp-sidebar-shell");

      if (!shell) return;
      setSidebarOpen(shell, shell.getAttribute("data-sidebar-open") !== "true");
    });
  }

  function bindSidebar(shell: HTMLElement) {
    if (shell.dataset.sidebarBound === "true") return;
    shell.dataset.sidebarBound = "true";

    shell
      .querySelector<HTMLElement>("[data-sidebar-backdrop]")
      ?.addEventListener("click", () => setSidebarOpen(shell, false));
  }

  function bindSidebars() {
    document.querySelectorAll<HTMLElement>(".sp-sidebar-shell").forEach(bindSidebar);
    document.querySelectorAll<HTMLElement>("[data-sidebar-toggle]").forEach(bindSidebarToggle);
  }

  bindSidebars();
  document.addEventListener("astro:page-load", bindSidebars);
</script>

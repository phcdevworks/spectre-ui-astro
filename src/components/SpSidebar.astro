---
import type { SidebarRecipeOptions } from "@phcdevworks/spectre-ui";
import {
  getSidebarClasses,
  getSidebarBackdropClasses,
  getSidebarToggleClasses,
} from "@phcdevworks/spectre-ui";

type SpSidebarElement = "aside" | "div" | "nav";

interface SpSidebarProps extends SidebarRecipeOptions {
  as?: SpSidebarElement;
  class?: string;
  id?: string;
  "aria-label"?: string;
  toggleLabel?: string;
  /** Suppress the built-in toggle button, e.g. when rendering SpSidebarToggle in SpNav instead. */
  hideToggle?: boolean;

  [key: string]: unknown;
}

const {
  bordered,
  as: Tag = "aside",
  class: className,
  id,
  "aria-label": ariaLabel,
  toggleLabel = "Toggle sidebar",
  hideToggle = false,
  ...rest
} = Astro.props as SpSidebarProps;

const classes = getSidebarClasses({ bordered });
const finalClass = [classes, className].filter(Boolean).join(" ");
const backdropClass = getSidebarBackdropClasses();
const toggleClass = getSidebarToggleClasses();
const wrapperId = id ? `${id}-shell` : undefined;
const shellId = wrapperId ?? "sp-sidebar-shell-default";
---

<div class="sp-sidebar-shell" id={shellId} data-sidebar-open="false">
  {
    !hideToggle && (
      <button
        type="button"
        class={toggleClass}
        aria-label={toggleLabel}
        data-sidebar-toggle
        data-sidebar-shell-target={shellId}
      >
        <slot name="toggle-icon">&#9776;</slot>
      </button>
    )
  }
  <div class={backdropClass} data-sidebar-backdrop></div>
  <Tag class={finalClass} id={id} aria-label={ariaLabel} {...rest}>
    <slot />
  </Tag>
</div>

<script>
  function bindSidebar(shell: HTMLElement) {
    if (shell.dataset.sidebarBound === "true") return;
    shell.dataset.sidebarBound = "true";

    const backdrop = shell.querySelector<HTMLElement>("[data-sidebar-backdrop]");

    const close = () => {
      shell.setAttribute("data-sidebar-open", "false");
    };

    const open = () => {
      shell.setAttribute("data-sidebar-open", "true");
    };

    const toggleHandler = () => {
      const isOpen = shell.getAttribute("data-sidebar-open") === "true";
      isOpen ? close() : open();
    };

    document
      .querySelectorAll<HTMLElement>(`[data-sidebar-toggle][data-sidebar-shell-target="${shell.id}"]`)
      .forEach((toggle) => toggle.addEventListener("click", toggleHandler));

    backdrop?.addEventListener("click", close);
  }

  document.querySelectorAll<HTMLElement>(".sp-sidebar-shell").forEach(bindSidebar);
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".sp-sidebar-shell").forEach(bindSidebar);
  });
</script>

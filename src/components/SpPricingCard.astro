---
import {
  getPricingCardClasses,
  getPricingCardBadgeClasses,
  getPricingCardPriceContainerClasses,
  getPricingCardPriceClasses,
  getPricingCardDescriptionClasses,
  type PricingCardRecipeOptions,
} from "@phcdevworks/spectre-ui";
import { resolveInteractiveAttrs } from "./sp-interactive.shared";

type SpPricingCardElement =
  | "div"
  | "section"
  | "article"
  | "aside"
  | "header"
  | "footer"
  | "main"
  | "nav"
  | "form"
  | "a"
  | "button"
  | "li";

interface SpPricingCardProps extends PricingCardRecipeOptions {
  as?: SpPricingCardElement;
  class?: string;

  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;

  type?: "button" | "submit" | "reset";
  tabindex?: number;
  "aria-label"?: string;

  [key: string]: any;
}

const {
  featured,
  interactive,
  disabled,
  loading,
  hovered,
  focused,
  active,
  as: Tag = "div",
  class: className,
  href,
  target,
  rel,
  type,
  tabindex,
  "aria-label": ariaLabel,
  ...rest
} = Astro.props as SpPricingCardProps;

const isPricingCardDisabled = disabled || loading;

const classes = getPricingCardClasses({
  featured,
  interactive,
  disabled: isPricingCardDisabled,
  loading,
  hovered,
  focused,
  active,
});
const finalClass = [classes, className].filter(Boolean).join(" ");

const { finalType, finalHref, finalTabIndex } = resolveInteractiveAttrs({
  Tag,
  isDisabled: isPricingCardDisabled,
  href,
  type,
  tabindex,
  interactive,
});

const badgeClasses = getPricingCardBadgeClasses();
const priceContainerClasses = getPricingCardPriceContainerClasses();
const priceClasses = getPricingCardPriceClasses();
const descriptionClasses = getPricingCardDescriptionClasses();
---

<Tag
  class={finalClass}
  href={finalHref}
  target={Tag === "a" ? target : undefined}
  rel={Tag === "a" ? rel : undefined}
  type={finalType}
  disabled={Tag === "button" && isPricingCardDisabled ? true : undefined}
  role={interactive && Tag !== "button" && Tag !== "a" ? "button" : undefined}
  aria-disabled={isPricingCardDisabled ? "true" : undefined}
  aria-busy={loading ? "true" : undefined}
  aria-label={ariaLabel}
  tabindex={finalTabIndex}
  {...rest}
>
  <slot name="header" />

  {
    Astro.slots.has("badge") && (
      <div class={badgeClasses}>
        <slot name="badge" />
      </div>
    )
  }

  {
    Astro.slots.has("price") && (
      <div class={priceContainerClasses}>
        <div class={priceClasses}>
          <slot name="price" />
        </div>
      </div>
    )
  }

  {
    Astro.slots.has("description") && (
      <div class={descriptionClasses}>
        <slot name="description" />
      </div>
    )
  }

  <slot />

  <slot name="footer" />
</Tag>

---
import type { CheckboxRecipeOptions } from "@phcdevworks/spectre-ui";
import { getCheckboxClasses } from "@phcdevworks/spectre-ui";

interface SpCheckboxProps extends CheckboxRecipeOptions {
  class?: string;
  id?: string;
  name?: string;
  value?: string;
  required?: boolean;
  form?: string;
  "aria-label"?: string;
  "aria-describedby"?: string;

  [key: string]: unknown;
}

const {
  checked,
  disabled,
  class: className,
  id,
  name,
  value,
  required,
  form,
  "aria-label": ariaLabel,
  "aria-describedby": ariaDescribedby,
  ...rest
} = Astro.props as SpCheckboxProps;

const classes = getCheckboxClasses({ checked, disabled });
const finalClass = [classes, className].filter(Boolean).join(" ");
---

<input
  type="checkbox"
  class={finalClass}
  id={id}
  name={name}
  value={value}
  checked={checked}
  disabled={disabled}
  required={required}
  form={form}
  aria-label={ariaLabel}
  aria-describedby={ariaDescribedby}
  aria-disabled={disabled ? "true" : undefined}
  {...rest}
/>

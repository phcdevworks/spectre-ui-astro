---
import {
  SpBadge,
  SpButton,
  SpCard,
  SpIconBox,
  SpTestimonial,
  SpPricingCard,
  SpRating,
} from "@phcdevworks/spectre-ui-astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Marketing — Spectre UI Astro">
  <div class="sp-stack page">

    <header class="sp-stack header">
      <div class="sp-stack">
        <p class="eyebrow">Spectre Examples</p>
        <h1>Marketing</h1>
        <p class="subtitle">
          Hero and feature layouts with cards, badges, and icon boxes.
        </p>
      </div>
    </header>

    <section class="hero">
      <div class="sp-stack feature">
        <SpBadge variant="warning">New release</SpBadge>
        <h2 class="hero-title">Launch faster with Spectre</h2>
        <p class="hero-copy">
          Prebuilt tokens, UI recipes, and Astro adapters so you can ship
          consistent experiences quickly.
        </p>
        <div class="sp-hstack actions">
          <SpButton variant="primary" size="lg">Start free</SpButton>
          <SpButton variant="ghost" size="lg">View docs</SpButton>
        </div>
      </div>

      <SpCard variant="elevated">
        <div class="sp-stack feature">
          <h3 class="card-title">
            <SpIconBox variant="primary" size="sm" aria-hidden="true">
              <svg class="icon" viewBox="0 0 24 24">
                <path fill="currentColor" d="M5 3h14l-1.5 13h-11zM9 21h6v-2H9z"
                ></path>
              </svg>
            </SpIconBox>
            Reliability
          </h3>
          <p>Backed by type-safe recipes and a single CSS entry point.</p>
          <div class="sp-hstack badge-row">
            <SpBadge variant="primary">Tokens</SpBadge>
            <SpBadge variant="success">Recipes</SpBadge>
            <SpBadge variant="danger">Adapters</SpBadge>
          </div>
        </div>
      </SpCard>
    </section>

    <section class="grid three">
      <SpCard variant="elevated">
        <div class="sp-stack feature">
          <SpIconBox variant="primary" size="sm" aria-hidden="true">
            <svg class="icon" viewBox="0 0 24 24">
              <path
                fill="currentColor"
                d="M12 2 2 7l10 5 10-5zm-7.5 9.5L12 17l7.5-5.5V17L12 22 4.5 17z"
              ></path>
            </svg>
          </SpIconBox>
          <h3 class="card-title">Composable</h3>
          <p>Build cards, CTAs, and forms from the same primitives.</p>
          <SpButton variant="primary" size="sm">Learn more</SpButton>
        </div>
      </SpCard>

      <SpCard variant="outline">
        <div class="sp-stack feature">
          <SpIconBox variant="success" size="sm" aria-hidden="true">
            <svg class="icon" viewBox="0 0 24 24">
              <path
                fill="currentColor"
                d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"></path>
            </svg>
          </SpIconBox>
          <h3 class="card-title">Accessible</h3>
          <p>Semantic markup with labeled inputs and aria-aware controls.</p>
          <SpButton variant="ghost" size="sm">Accessibility</SpButton>
        </div>
      </SpCard>

      <SpCard variant="ghost">
        <div class="sp-stack feature">
          <SpIconBox variant="warning" size="sm" aria-hidden="true">
            <svg class="icon" viewBox="0 0 24 24">
              <path fill="currentColor" d="M11 15h2v2h-2zm0-8h2v6h-2z"></path>
            </svg>
          </SpIconBox>
          <h3 class="card-title">Transparent</h3>
          <p>Clear separation of tokens, UI recipes, and Astro wrappers.</p>
          <SpButton variant="secondary" size="sm">View roadmap</SpButton>
        </div>
      </SpCard>
    </section>

    <section class="sp-stack" style="margin-top: var(--sp-layout-section-gap-md)">
      <h2 style="margin-bottom: var(--sp-layout-stack-gap-sm)">Pricing & Testimonials</h2>
      <div class="grid three">
        <SpPricingCard featured={false}>
          <h3 slot="header" style="margin:0;">Starter</h3>
          <span slot="badge">Basic</span>
          <span slot="price">$9 / mo</span>
          <span slot="description">Perfect for simple projects.</span>
          <ul class="sp-stack" style="padding-left:1.5rem; margin:1rem 0; gap:0.5rem">
            <li>1 Project</li>
            <li>Basic Analytics</li>
          </ul>
          <SpButton slot="footer" variant="secondary" style="width:100%">Choose Starter</SpButton>
        </SpPricingCard>

        <SpPricingCard featured={true}>
          <h3 slot="header" style="margin:0;">Pro</h3>
          <span slot="badge">Popular</span>
          <span slot="price">$29 / mo</span>
          <span slot="description">For growing teams and businesses.</span>
          <ul class="sp-stack" style="padding-left:1.5rem; margin:1rem 0; gap:0.5rem">
            <li>Unlimited Projects</li>
            <li>Advanced Analytics</li>
            <li>Priority Support</li>
          </ul>
          <SpButton slot="footer" variant="primary" style="width:100%">Get Pro</SpButton>
        </SpPricingCard>

        <SpPricingCard featured={false} disabled>
          <h3 slot="header" style="margin:0;">Enterprise</h3>
          <span slot="badge">Waitlist</span>
          <span slot="price">Custom</span>
          <span slot="description">For large scale applications.</span>
          <ul class="sp-stack" style="padding-left:1.5rem; margin:1rem 0; gap:0.5rem">
            <li>Custom Solutions</li>
            <li>24/7 Support</li>
          </ul>
          <SpButton slot="footer" variant="secondary" style="width:100%" disabled>Join Waitlist</SpButton>
        </SpPricingCard>

        <div class="sp-stack" style="gap: var(--sp-layout-stack-gap-md);">
          <SpCard variant="elevated">
            <SpTestimonial>
              <p slot="quote" style="margin:0;">"Spectre UI has fundamentally changed how quickly we can prototype and ship our Astro projects. It's an absolute game-changer."</p>
              <div slot="author-name">Jane Doe</div>
              <div slot="author-title">Frontend Lead at Acme Corp</div>
            </SpTestimonial>
            <SpRating value={5} max={5} style="margin-top:1rem" />
          </SpCard>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    gap: var(--sp-layout-section-gap-lg);
    width: min(1150px, 100%);
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-layout-stack-gap-sm);
  }

  .eyebrow {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    font-size: var(--sp-font-xs-size);
    color: var(--sp-text-on-page-muted);
    margin: 0;
  }

  .subtitle {
    margin: 0;
    color: var(--sp-text-on-page-muted);
    max-width: 60ch;
  }

  .hero {
    display: grid;
    gap: var(--sp-layout-section-gap-md);
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    align-items: center;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: var(--sp-layout-stack-gap-sm);
  }

  .hero-title {
    margin: 0;
  }

  .hero-copy {
    margin: 0 0 0.5rem;
    color: var(--sp-text-on-page-muted);
    max-width: 60ch;
  }

  .actions {
    display: flex;
    gap: var(--sp-layout-stack-gap-sm);
    flex-wrap: wrap;
    align-items: center;
  }

  .badge-row {
    display: flex;
    gap: var(--sp-layout-stack-gap-sm);
    flex-wrap: wrap;
    align-items: center;
  }

  .grid {
    display: grid;
    gap: var(--sp-layout-section-gap-md);
  }

  .grid.three {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .card-title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--sp-layout-stack-gap-sm);
  }

  .icon {
    width: 1.2em;
    height: 1.2em;
  }
</style>
